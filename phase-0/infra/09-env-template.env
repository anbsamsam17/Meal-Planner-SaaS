# .env.example — Template des variables d'environnement
#
# IMPORTANT : Ce fichier est COMMITÉ dans le repo (pas de secrets ici).
# Copier ce fichier en .env.local et remplir les valeurs réelles.
# .env.local est dans .gitignore — ne jamais commiter les vraies valeurs.
#
# En production : ces variables sont gérées par Doppler.
# En dev local  : créer un .env.local à la racine du repo.
#
# Convention : valeurs vides = obligatoire | valeurs par défaut = optionnel

# =============================================================================
# APPLICATION
# =============================================================================

# Environnement d'exécution : development | staging | production | test
ENVIRONMENT=development

# URL de base de l'API (sans slash final)
# Dev : http://localhost:8000 | Prod : https://api.mealplanner.fr
API_BASE_URL=http://localhost:8000

# =============================================================================
# BASE DE DONNÉES — Supabase / PostgreSQL
# =============================================================================

# URL du projet Supabase (format : https://<ref>.supabase.co)
SUPABASE_URL=

# Clé publique Supabase — SAFE côté client Next.js (RLS actif)
# À copier dans NEXT_PUBLIC_SUPABASE_ANON_KEY également
SUPABASE_ANON_KEY=

# Clé service role Supabase — JAMAIS côté client, backend uniquement
# Bypass RLS — protéger comme un mot de passe root
SUPABASE_SERVICE_ROLE_KEY=

# Connection string PostgreSQL pour SQLAlchemy async (asyncpg)
# Format : postgresql+asyncpg://user:password@host:port/database
# Dev local : postgresql+asyncpg://mealplanner:mealplanner_dev_password@localhost:5432/mealplanner_dev
# Prod : récupérer depuis Supabase Dashboard > Settings > Database > Connection string > Python
DATABASE_URL=postgresql+asyncpg://mealplanner:mealplanner_dev_password@localhost:5432/mealplanner_dev

# Pool de connexions (optionnel — valeurs par défaut raisonnables)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# REDIS — Broker Celery + cache
# =============================================================================

# URL Redis
# Dev local : redis://localhost:6379/0
# Railway : injecté automatiquement via ${{Redis.REDIS_URL}}
REDIS_URL=redis://localhost:6379/0

# Base Redis dédiée au cache applicatif (séparée du broker Celery)
REDIS_CACHE_URL=redis://localhost:6379/1

# =============================================================================
# IA — Claude / Anthropic
# =============================================================================

# Clé API Anthropic (claude-sonnet-4-5 selon ROADMAP §05)
# https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# Modèle par défaut (ne pas hardcoder dans le code — utiliser cette variable)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Limite de tokens par requête (protection coûts)
ANTHROPIC_MAX_TOKENS=4096

# =============================================================================
# OBJECT STORAGE — Cloudflare R2
# =============================================================================

# Access Key ID du token R2
R2_ACCESS_KEY=

# Secret Access Key du token R2
R2_SECRET=

# Nom du bucket pour les PDFs hebdomadaires
R2_BUCKET=mealplanner-pdfs

# Nom du bucket pour les images générées (Stability AI)
R2_IMAGES_BUCKET=mealplanner-images

# Endpoint R2 : https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# URL publique pour accéder aux fichiers (si bucket public ou signed URLs)
R2_PUBLIC_URL=

# =============================================================================
# PAIEMENT — Stripe
# =============================================================================

# Clé secrète Stripe
# Dev/staging : sk_test_... | Production : sk_live_...
STRIPE_SECRET_KEY=sk_test_...

# Secret du webhook Stripe (généré lors de la création de l'endpoint webhook)
# Format : whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des produits Stripe (créer dans le dashboard Stripe)
STRIPE_PRICE_FAMILLE=price_...   # Plan Famille 9,99€/mois
STRIPE_PRICE_COACH=price_...     # Plan Coach 14,99€/mois

# =============================================================================
# MONITORING — Sentry
# =============================================================================

# DSN du projet API Sentry
# https://sentry.io/<org>/<project>/settings/keys/
SENTRY_DSN=

# Token d'authentification pour l'upload des source maps (CI uniquement)
SENTRY_AUTH_TOKEN=

# Organisation Sentry (slug)
SENTRY_ORG=mealplanner-saas

# Projet Sentry API
SENTRY_PROJECT=api

# Traces sample rate (0.0 à 1.0) — 0.1 en prod pour économiser le quota
SENTRY_TRACES_SAMPLE_RATE=1.0

# =============================================================================
# ANALYTICS — PostHog EU
# =============================================================================

# Clé projet PostHog
POSTHOG_KEY=

# Host PostHog EU (RGPD compliant)
POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# EMAILS — Resend
# =============================================================================

# Clé API Resend
RESEND_API_KEY=

# Adresse email expéditeur (vérifiée dans Resend)
RESEND_FROM_EMAIL=hello@mealplanner.fr

# =============================================================================
# APIS RECETTES
# =============================================================================

# Spoonacular API Key
# https://spoonacular.com/food-api/console#Dashboard
SPOONACULAR_KEY=

# Edamam Recipe Search API
# https://developer.edamam.com/admin/applications
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# =============================================================================
# GÉNÉRATION D'IMAGES — Stability AI
# =============================================================================

# Clé API Stability AI (pour la génération de photos recettes dans les PDFs)
# https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Modèle Stability AI par défaut
STABILITY_MODEL=stable-diffusion-3-medium

# =============================================================================
# FEATURE FLAGS — Flagsmith
# =============================================================================

# Clé d'environnement Flagsmith
# Dev : clé env "Development" | Staging : "Staging" | Prod : "Production"
FLAGSMITH_ENV_KEY=

# =============================================================================
# AUTHENTIFICATION — Supabase Auth
# =============================================================================

# Secret JWT pour la validation des tokens Supabase (dans les Route Handlers Next.js)
# Récupérer depuis Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=

# =============================================================================
# VARIABLES NEXT.JS PUBLIQUES (préfixe NEXT_PUBLIC_ obligatoire)
# Ces variables sont exposées au navigateur — ne jamais y mettre de secrets
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL de l'API backend (visible dans le bundle JS)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Analytics PostHog EU
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Monitoring Sentry (DSN public — safe à exposer)
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags Flagsmith (clé d'env — safe à exposer)
NEXT_PUBLIC_FLAGSMITH_ENV_KEY=

# Stripe clé publique
# Dev/staging : pk_test_... | Production : pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# DÉVELOPPEMENT LOCAL UNIQUEMENT (ne pas définir en production)
# =============================================================================

# SMTP MailHog (capture les emails en dev sans les envoyer)
SMTP_HOST=localhost
SMTP_PORT=1025

# MinIO (fallback R2 local)
MINIO_ROOT_USER=mealplanner_access_key
MINIO_ROOT_PASSWORD=mealplanner_minio_password
MINIO_ENDPOINT=http://localhost:9000

# Activer le mode debug FastAPI (rechargement automatique)
DEBUG=true
