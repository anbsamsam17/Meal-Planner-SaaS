# ============================================================
# Variables d'environnement — apps/web
# Copier ce fichier en .env.local et remplir les valeurs
# NE PAS committer .env.local dans git
# ============================================================

# -----------------------------------------------
# Supabase — Authentification et base de données
# Obtenir sur : https://supabase.com/dashboard/project/<your-project>/settings/api
# -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# -----------------------------------------------
# API FastAPI — Backend Python
# En développement local : http://localhost:8000
# En production : URL de votre instance Railway/Render
# -----------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------
# PostHog — Analytics produit (optionnel en dev)
# Obtenir sur : https://app.posthog.com/project/settings
# Mettre une chaîne vide pour désactiver
# -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------
# Sentry — Monitoring des erreurs (optionnel en dev)
# Obtenir sur : https://sentry.io/settings/<your-org>/projects/<your-project>/keys/
# -----------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# -----------------------------------------------
# Variables serveur uniquement (sans NEXT_PUBLIC_)
# Non exposées au navigateur
# -----------------------------------------------

# Clé de service Supabase (accès admin — uniquement côté serveur)
# NE PAS préfixer avec NEXT_PUBLIC_ !
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
