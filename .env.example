# =============================================================================
# .env.example — Template des variables d'environnement Presto
# =============================================================================
#
# IMPORTANT : Ce fichier est COMMITÉ dans le repo — il ne contient AUCUN secret.
# Utilisation :
#   cp .env.example .env.local
#   # Puis remplir les valeurs réelles dans .env.local (jamais commité)
#
# En production : toutes ces variables sont gérées par Doppler (pas de .env en prod).
# En dev local  : créer .env.local à la racine du monorepo.
#
# Légende :
#   [OBLIGATOIRE Phase 1] — requis pour démarrer l'application dès maintenant
#   [OPTIONNEL Phase 1]   — peut rester vide en Phase 1, fonctionnalité non active
#   [Phase 2+]            — sera requis dans une phase ultérieure
#   [Phase 3]             — requis pour la génération PDF et les plans avancés

# =============================================================================
# APPLICATION
# =============================================================================

# Environnement d'exécution : development | staging | production | test
# FIX Phase 1 (review 2026-04-12) : config.py lit ENV (pas ENVIRONMENT) — renommé pour cohérence.
# AliasChoices("ENV", "ENVIRONMENT") côté Pydantic accepte les deux noms, mais ENV est canonique.
# [OBLIGATOIRE Phase 1]
ENV=development

# URL de base de l'API FastAPI (sans slash final)
# Dev : http://localhost:8001 (port 8001 si 8000 est occupé par un autre service)
# Si le port 8000 est libre sur votre machine, vous pouvez garder 8000.
# Staging/Prod : https://api.presto.fr
# [OBLIGATOIRE Phase 1]
API_BASE_URL=http://localhost:8001

# =============================================================================
# BASE DE DONNÉES — Supabase / PostgreSQL
# Obtenir sur : https://supabase.com/dashboard → votre projet → Settings → API
# =============================================================================

# URL du projet Supabase (format : https://<ref>.supabase.co)
# Dashboard : Settings → API → Project URL
# [OBLIGATOIRE Phase 1 — laisser vide si on utilise le Postgres Docker local]
SUPABASE_URL=

# Clé publique Supabase (anon key) — SAFE côté client Next.js (RLS actif)
# Dashboard : Settings → API → Project API keys → anon / public
# [OBLIGATOIRE Phase 1 — laisser vide si Postgres Docker local]
SUPABASE_ANON_KEY=

# Clé service role Supabase — JAMAIS côté client, backend uniquement
# Dashboard : Settings → API → Project API keys → service_role / secret
# ATTENTION : bypass RLS — protéger comme un mot de passe root
# [OBLIGATOIRE Phase 1 — laisser vide si Postgres Docker local]
SUPABASE_SERVICE_ROLE_KEY=

# Connection string PostgreSQL pour SQLAlchemy async (asyncpg)
# Format : postgresql+asyncpg://user:password@host:port/database
# Dev local (Docker) : port 5433 car le container expose 5433:5432 pour éviter
#   les conflits avec une instance PostgreSQL locale éventuelle sur le port 5432.
# Prod Supabase : Supabase Dashboard → Settings → Database → Connection string → Python
# [OBLIGATOIRE Phase 1]
DATABASE_URL=postgresql+asyncpg://mealplanner:mealplanner_dev_password@localhost:5433/mealplanner_dev

# Taille du pool de connexions SQLAlchemy (optionnel — valeurs par défaut raisonnables)
# [OPTIONNEL Phase 1]
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# REDIS — Broker Celery + cache applicatif
# Dev local : instance Docker (docker-compose.dev.yml)
# Production : Railway plugin Redis → injecte automatiquement REDIS_URL
# =============================================================================

# URL principale Redis (broker Celery + base 0)
# Dev local : redis://localhost:6379/0 (port 6379 standard, pas de conflit habituel)
# [OBLIGATOIRE Phase 1]
REDIS_URL=redis://localhost:6379/0

# Base Redis dédiée au cache applicatif (séparée du broker Celery — base 1)
# [OBLIGATOIRE Phase 1]
REDIS_CACHE_URL=redis://localhost:6379/1

# Base Redis dédiée au rate limiting (séparée du cache — base 1, résiduel Phase 0)
# [OPTIONNEL Phase 1 — utilisé par slowapi middleware]
REDIS_RATE_LIMIT_DB=1

# =============================================================================
# LLM — GOOGLE GEMINI (validation + tagging recettes)
# Swap Anthropic → Gemini (2026-04-12) : free tier 15 req/min suffisant pour batch nocturne
# Obtenir la clé : https://aistudio.google.com/apikey
# Free tier : 15 req/min, 1 500 req/jour (suffisant pour le batch nocturne 50k recettes)
# =============================================================================

# Clé API Google AI Studio — obligatoire si LLM_PROVIDER=gemini
# Dashboard : https://aistudio.google.com/apikey → Create API Key
# [OBLIGATOIRE Phase 1 — laisser vide désactive les agents IA]
GOOGLE_AI_API_KEY=

# Modèle Gemini à utiliser (ne pas hardcoder dans le code)
# gemini-2.0-flash : rapide, gratuit jusqu'à 15 req/min
# [OBLIGATOIRE Phase 1]
GEMINI_MODEL=gemini-2.0-flash

# Provider LLM actif : "gemini" (défaut, gratuit) ou "anthropic" (payant)
# Pour revenir à Anthropic : LLM_PROVIDER=anthropic + remplir ANTHROPIC_API_KEY ci-dessous
# [OBLIGATOIRE Phase 1]
LLM_PROVIDER=gemini

# =============================================================================
# ANTHROPIC (optionnel — uniquement si LLM_PROVIDER=anthropic)
# Obtenir sur : https://console.anthropic.com/api-keys
# =============================================================================

# Clé API Anthropic — plus obligatoire depuis la migration Gemini (2026-04-12)
# Décommenter et remplir UNIQUEMENT si LLM_PROVIDER=anthropic
# [OPTIONNEL — requis uniquement si LLM_PROVIDER=anthropic]
# ANTHROPIC_API_KEY=

# Modèle Anthropic (si LLM_PROVIDER=anthropic)
# Valeurs possibles : claude-sonnet-4-5 | claude-3-5-haiku-latest
# [OPTIONNEL]
# ANTHROPIC_MODEL=claude-sonnet-4-5

# =============================================================================
# OBJECT STORAGE — Cloudflare R2
# Obtenir sur : https://dash.cloudflare.com → R2 Object Storage → Manage R2 API Tokens
# En dev local : remplacer par MinIO (voir section DÉVELOPPEMENT LOCAL ci-dessous)
# =============================================================================

# Access Key ID du token R2 (Cloudflare Dashboard → R2 → Manage R2 API Tokens)
# [OPTIONNEL Phase 1 — MinIO Docker en dev suffit]
R2_ACCESS_KEY=

# Secret Access Key du token R2
# [OPTIONNEL Phase 1 — MinIO Docker en dev suffit]
R2_SECRET=

# Nom du bucket R2 pour les PDFs hebdomadaires générés
# [OPTIONNEL Phase 1]
R2_BUCKET=mealplanner-pdfs

# Nom du bucket R2 pour les images générées par Stability AI
# [OPTIONNEL Phase 1]
R2_IMAGES_BUCKET=mealplanner-images

# Endpoint R2 : https://<account-id>.r2.cloudflarestorage.com
# Cloudflare Dashboard → R2 → Buckets → votre bucket → Settings → S3 API
# [OPTIONNEL Phase 1]
R2_ENDPOINT=

# URL publique pour accéder aux fichiers (bucket public ou signed URLs)
# [OPTIONNEL Phase 1]
R2_PUBLIC_URL=

# ═══════════════════════════════════════════════════════════════════════════
# PAIEMENT — Stripe (Phase 2)
# Obtenir sur : https://dashboard.stripe.com/apikeys
# Dev/staging : toujours utiliser les clés de test (sk_test_... / pk_test_...)
# Mode test : sk_test_... / pk_test_...
# Créer les produits/prix dans Stripe Dashboard → Products
#
# NOTE backend-developer : rendre ces settings optionnels dans config.py
# (Optional[str] = None). Les endpoints Stripe doivent retourner HTTP 503
# si STRIPE_SECRET_KEY n'est pas définie — pas de crash au démarrage API.
# ═══════════════════════════════════════════════════════════════════════════

# Clé secrète Stripe — JAMAIS exposée côté client
# Dashboard Stripe : Developers → API keys → Secret key
# Dev : sk_test_... | Production : sk_live_...
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2 pour l'activation des abonnements]
STRIPE_SECRET_KEY=sk_test_...

# Secret du webhook Stripe (généré lors de la création de l'endpoint webhook)
# Dashboard Stripe : Developers → Webhooks → votre endpoint → Signing secret
# Format : whsec_...
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2 dès qu'on teste les webhooks]
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des prix Stripe (créer les produits dans le Dashboard Stripe)
# Dashboard Stripe : Products → votre produit → Price ID (format price_...)
# Plan Famille : 9,99€/mois
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2 pour l'activation des abonnements]
STRIPE_PRICE_FAMILLE=price_...

# Plan Coach : 14,99€/mois
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2]
STRIPE_PRICE_COACH=price_...

# URL de retour après Stripe Checkout (succès ou annulation)
# Dev : http://localhost:3000 | Prod : https://app.presto.fr
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2]
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# =============================================================================
# MONITORING — Sentry
# Obtenir sur : https://sentry.io → votre organisation → votre projet → Settings → Keys
# =============================================================================

# DSN du projet API Sentry (Data Source Name)
# Sentry Dashboard : Settings → Projects → votre projet → Client Keys (DSN)
# [OPTIONNEL Phase 1 — très recommandé en staging/prod]
SENTRY_DSN=

# Token d'authentification pour l'upload des source maps (CI uniquement)
# Sentry Dashboard : Settings → Account → API → Auth Tokens
# [OPTIONNEL Phase 1 — uniquement pour le job CI]
SENTRY_AUTH_TOKEN=

# Slug de l'organisation Sentry (visible dans l'URL : sentry.io/<org>)
# [OPTIONNEL Phase 1]
SENTRY_ORG=presto-saas

# Nom du projet Sentry pour l'API FastAPI
# [OPTIONNEL Phase 1]
SENTRY_PROJECT=api

# Taux d'échantillonnage des traces de performance (0.0 à 1.0)
# Dev/staging : 1.0 (tout capturer) | Prod : 0.1 (10% pour économiser le quota)
# [OPTIONNEL Phase 1]
SENTRY_TRACES_SAMPLE_RATE=1.0

# =============================================================================
# ANALYTICS — PostHog EU (RGPD compliant)
# Obtenir sur : https://eu.posthog.com → Project Settings → Project API Key
# =============================================================================

# Clé du projet PostHog
# Dashboard PostHog : Project Settings → Project API Key
# [OPTIONNEL Phase 1 — recommandé pour mesurer l'onboarding]
POSTHOG_KEY=

# Host PostHog EU (données hébergées en Europe — RGPD)
# [OPTIONNEL Phase 1]
POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# EMAILS — Resend
# Obtenir sur : https://resend.com/api-keys
# En dev local : les emails sont capturés par MailHog (pas besoin de vraie clé)
# =============================================================================

# Clé API Resend pour l'envoi d'emails transactionnels
# Dashboard Resend : API Keys → Create API Key
# [OPTIONNEL Phase 1 — MailHog Docker suffit en dev]
RESEND_API_KEY=

# Adresse email expéditeur (doit être vérifiée dans Resend)
# Dashboard Resend : Domains → Add Domain → puis vérifier le DNS
# [OPTIONNEL Phase 1]
RESEND_FROM_EMAIL=hello@presto.fr

# =============================================================================
# APIS RECETTES
# Obtenir sur les dashboards respectifs
# =============================================================================

# Spoonacular API Key — recherche et données de recettes
# Dashboard : https://spoonacular.com/food-api/console#Dashboard → API Key
# FIX Phase 1 (review 2026-04-12) : config.py attend SPOONACULAR_API_KEY (pas SPOONACULAR_KEY).
# Mismatch → ValidationError Pydantic au démarrage API. Variable renommée pour correspondre.
# [OPTIONNEL Phase 1 — requis pour l'agent RECIPE_SCOUT]
SPOONACULAR_API_KEY=

# Edamam Recipe Search API
# Dashboard : https://developer.edamam.com/admin/applications → Create App
# [OPTIONNEL Phase 1 — fallback pour RECIPE_SCOUT]
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# =============================================================================
# GÉNÉRATION D'IMAGES — Stability AI
# Obtenir sur : https://platform.stability.ai/account/keys
# =============================================================================

# Clé API Stability AI pour la génération de photos recettes dans les PDFs
# Dashboard : https://platform.stability.ai/account/keys → Create API Key
# [OPTIONNEL Phase 1 — requis Phase 3 pour la génération de livres PDF]
STABILITY_API_KEY=

# Modèle Stability AI par défaut
# [OPTIONNEL Phase 1]
STABILITY_MODEL=stable-diffusion-3-medium

# =============================================================================
# FEATURE FLAGS — Flagsmith
# Obtenir sur : https://app.flagsmith.com → votre projet → Environments
# =============================================================================

# Clé d'environnement Flagsmith
# Dashboard Flagsmith : votre projet → Environments → Development → SDK Keys → Client-side
# Dev : clé env "Development" | Staging : "Staging" | Prod : "Production"
# [OBLIGATOIRE Phase 1 — requis par la règle CLAUDE.md (pas de if/else feature en dur)]
FLAGSMITH_ENV_KEY=

# =============================================================================
# AUTHENTIFICATION — Supabase Auth
# =============================================================================

# Secret JWT pour la validation stricte des tokens Supabase côté API FastAPI
# FIX Phase 1 (review 2026-04-12) : BUG #8 sécurité — validation JWT côté backend requiert
# cette clé pour verify_aud=True et algo HS256 explicite (audit H2 code-review).
# Dashboard Supabase : Settings → API → JWT Settings → JWT Secret
# ATTENTION : Ne JAMAIS exposer cette clé côté client ou dans le bundle Next.js.
# [OBLIGATOIRE Phase 1 dès qu'on active l'auth]
SUPABASE_JWT_SECRET=

# =============================================================================
# VARIABLES NEXT.JS PUBLIQUES (préfixe NEXT_PUBLIC_ obligatoire)
# Ces variables sont embarquées dans le bundle JavaScript du navigateur.
# ATTENTION : ne jamais y mettre de clés secrètes — tout est visible par les utilisateurs.
# =============================================================================

# URL Supabase (même valeur que SUPABASE_URL)
# [OBLIGATOIRE Phase 1 pour le frontend]
NEXT_PUBLIC_SUPABASE_URL=

# Clé anon Supabase (même valeur que SUPABASE_ANON_KEY — safe côté client avec RLS)
# [OBLIGATOIRE Phase 1 pour le frontend]
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL de l'API FastAPI (visible dans le bundle JS — pas de secrets dans les headers ici)
# Dev : http://localhost:8001 (aligné avec API_BASE_URL — port 8001 si 8000 est pris)
# Prod : https://api.presto.fr
# [OBLIGATOIRE Phase 1]
NEXT_PUBLIC_API_URL=http://localhost:8001

# Clé PostHog côté client (EU)
# [OPTIONNEL Phase 1]
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# DSN Sentry côté client (DSN public — safe à exposer dans le bundle)
# [OPTIONNEL Phase 1]
NEXT_PUBLIC_SENTRY_DSN=

# Clé d'environnement Flagsmith côté client (safe à exposer)
# [OPTIONNEL Phase 1]
NEXT_PUBLIC_FLAGSMITH_ENV_KEY=

# Clé publique Stripe — safe à exposer côté client
# Dev/staging : pk_test_... | Production : pk_live_...
# [OPTIONNEL Phase 1 — requis Phase 2 pour l'intégration paiement]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# GÉNÉRATION PDF — WeasyPrint / Gotenberg (Phase 3)
# =============================================================================

# URL du service Gotenberg (moteur PDF basé sur Chromium)
# En dev local : docker run --rm -p 3000:3000 gotenberg/gotenberg:8
# # GOTENBERG_URL=http://localhost:3000
# [Phase 3 — requis pour BOOK_GENERATOR]

# Clé API pour le service PDF si hébergé externalement
# # PDF_SERVICE_API_KEY=
# [Phase 3]

# =============================================================================
# DÉVELOPPEMENT LOCAL UNIQUEMENT
# Ces variables ne doivent PAS être définies en staging ou production.
# Elles sont utilisées par le docker-compose.dev.yml.
# =============================================================================

# MailHog — serveur SMTP de test qui capture tous les emails sans les envoyer
# Interface web : http://localhost:8025
# [OPTIONNEL Phase 1 — valeurs par défaut pour docker-compose.dev.yml]
SMTP_HOST=localhost
SMTP_PORT=1025

# MinIO — fallback local pour Cloudflare R2 (compatible API S3)
# Console web : http://localhost:9001 (presto_access_key / presto_minio_password)
# Ces variables sont utilisées par docker-compose.dev.yml pour configurer le serveur MinIO.
# [OPTIONNEL Phase 1 — valeurs par défaut pour docker-compose.dev.yml]
MINIO_ROOT_USER=mealplanner_access_key
MINIO_ROOT_PASSWORD=mealplanner_minio_password

# ═══════════════════════════════════════════════════════════════════════════
# MinIO SDK — Variables utilisées par le worker Python (aioboto3/boto3)
# Compatible avec Cloudflare R2 en prod (même API S3)
# En dev : pointe vers le container MinIO local
# En prod : remplacer par les credentials Cloudflare R2 (R2_ACCESS_KEY, R2_SECRET)
# ═══════════════════════════════════════════════════════════════════════════

# Endpoint MinIO (API S3 locale) — remplacer par R2_ENDPOINT en prod
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2 pour le stockage PDF]
MINIO_ENDPOINT=http://localhost:9000

# Access key du compte MinIO (= MINIO_ROOT_USER en dev)
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2]
MINIO_ACCESS_KEY=mealplanner_access_key

# Secret key du compte MinIO (= MINIO_ROOT_PASSWORD en dev)
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2]
MINIO_SECRET_KEY=mealplanner_minio_password

# Bucket pour les PDFs de planning hebdomadaire
# Créé automatiquement au démarrage par le service minio-init (docker-compose.dev.yml)
# [OPTIONNEL Phase 1 — OBLIGATOIRE Phase 2]
MINIO_BUCKET_PDFS=mealplanner-pdfs

# Bucket pour les images de recettes (Phase 3 — génération Stability AI)
# Créé automatiquement au démarrage par le service minio-init (docker-compose.dev.yml)
# [Phase 3]
MINIO_BUCKET_IMAGES=mealplanner-images

# Mode debug FastAPI (active le rechargement automatique et les tracebacks complets)
# Ne JAMAIS passer à true en production
# [OPTIONNEL Phase 1]
DEBUG=true
